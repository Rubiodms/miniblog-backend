{
  "name": "miniblog-backend",
  "version": "1.0.0",
  "description": "",
  "main": "server.js",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "dev": "nodemon server.js" 
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "vitest": "^4.1.5"
  },
  "vitest": {
    "environment": "node",
    "testTimeout": 15000,
    "include": [
      "tests/**/*.test.js"
    ],
    "globals": false,
    "pool": "forks",
    "poolOptions": {
      "forks": {
        "singleFork": true
      }
    }
  }
}
